{
  "$defs": {
    "PlanEvent": {
      "properties": {
        "job_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Job Id"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "step_index": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Step Index"
        },
        "timestamp": {
          "title": "Timestamp",
          "type": "string"
        },
        "type": {
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "timestamp",
        "type",
        "message"
      ],
      "title": "PlanEvent",
      "type": "object"
    },
    "PlanStepJob": {
      "properties": {
        "job_id": {
          "title": "Job Id",
          "type": "string"
        },
        "status": {
          "title": "Status",
          "type": "string"
        },
        "step_index": {
          "title": "Step Index",
          "type": "integer"
        }
      },
      "required": [
        "step_index",
        "job_id",
        "status"
      ],
      "title": "PlanStepJob",
      "type": "object"
    },
    "WorkflowCandidate": {
      "properties": {
        "contract_version": {
          "default": "1.0",
          "title": "Contract Version",
          "type": "string"
        },
        "goal": {
          "title": "Goal",
          "type": "string"
        },
        "steps": {
          "items": {
            "$ref": "#/$defs/WorkflowStep"
          },
          "title": "Steps",
          "type": "array"
        }
      },
      "required": [
        "goal"
      ],
      "title": "WorkflowCandidate",
      "type": "object"
    },
    "WorkflowStep": {
      "properties": {
        "artifact_outputs": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Artifact Outputs",
          "type": "object"
        },
        "capability": {
          "title": "Capability",
          "type": "string"
        },
        "consumes": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Consumes",
          "type": "object"
        },
        "contract_version": {
          "default": "1.0",
          "title": "Contract Version",
          "type": "string"
        },
        "produces": {
          "items": {
            "type": "string"
          },
          "title": "Produces",
          "type": "array"
        },
        "provider": {
          "default": "",
          "title": "Provider",
          "type": "string"
        },
        "reason": {
          "title": "Reason",
          "type": "string"
        },
        "requires": {
          "items": {
            "type": "string"
          },
          "title": "Requires",
          "type": "array"
        },
        "skill": {
          "default": "",
          "title": "Skill",
          "type": "string"
        },
        "version": {
          "default": "",
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "capability",
        "reason"
      ],
      "title": "WorkflowStep",
      "type": "object"
    }
  },
  "properties": {
    "approved_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Approved At"
    },
    "artifacts": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Artifacts",
      "type": "object"
    },
    "candidate": {
      "$ref": "#/$defs/WorkflowCandidate"
    },
    "capability_providers": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Capability Providers",
      "type": "object"
    },
    "capability_versions": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Capability Versions",
      "type": "object"
    },
    "completed_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Completed At"
    },
    "contract_version": {
      "default": "1.0",
      "title": "Contract Version",
      "type": "string"
    },
    "created_at": {
      "title": "Created At",
      "type": "string"
    },
    "error": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Error"
    },
    "events": {
      "items": {
        "$ref": "#/$defs/PlanEvent"
      },
      "title": "Events",
      "type": "array"
    },
    "inputs": {
      "additionalProperties": true,
      "title": "Inputs",
      "type": "object"
    },
    "missing_inputs": {
      "items": {
        "type": "string"
      },
      "title": "Missing Inputs",
      "type": "array"
    },
    "plan_id": {
      "title": "Plan Id",
      "type": "string"
    },
    "produced_artifacts": {
      "items": {
        "type": "string"
      },
      "title": "Produced Artifacts",
      "type": "array"
    },
    "status": {
      "default": "draft",
      "enum": [
        "draft",
        "waiting_for_approval",
        "approved",
        "running",
        "completed",
        "failed",
        "rejected",
        "cancelled"
      ],
      "title": "Status",
      "type": "string"
    },
    "step_approval_ids": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Step Approval Ids",
      "type": "object"
    },
    "step_jobs": {
      "items": {
        "$ref": "#/$defs/PlanStepJob"
      },
      "title": "Step Jobs",
      "type": "array"
    }
  },
  "required": [
    "plan_id",
    "candidate",
    "created_at"
  ],
  "title": "ExecutionPlan",
  "type": "object"
}
