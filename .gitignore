.env
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
work/jobs/*
work/scaffolds/*
!work/jobs/.gitkeep
!work/scaffolds/.gitkeep
.continue/

# Graphify query artifacts are tracked; local extraction state and caches are not.
graphify-out/cache/
graphify-out/.graphify_root
graphify-out/*/.graphify_labels.json
